# =============================================================================
# PPlaner — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.
# =============================================================================

# --- Google OAuth2 ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add all environments):
#   - http://localhost:4321/api/auth/callback  (local dev)
#   - https://your-app.vercel.app/api/auth/callback  (Vercel)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Session Encryption ---
# Generate with: openssl rand -hex 32
# MUST be at least 32 characters. Used to encrypt session cookies.
# TODO(security): Set this in Vercel Dashboard > Project Settings > Environment Variables
SESSION_SECRET=generate-a-random-32-char-string-here

# --- App ---
# Set to 'production' on Vercel (Vercel sets this automatically)
NODE_ENV=development
